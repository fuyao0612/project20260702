<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中...</view>

  <view wx:else class="form">
    <view class="field">
      <view class="label">类型</view>
      <view class="segmented">
        <view class="segment {{form.type === 'expense' ? 'active' : ''}}" data-type="expense" bindtap="chooseType">支出</view>
        <view class="segment {{form.type === 'income' ? 'active' : ''}}" data-type="income" bindtap="chooseType">收入</view>
      </view>
    </view>

    <view class="field">
      <view class="label">金额</view>
      <input class="input" type="digit" placeholder="例如 19.5" value="{{form.amountYuan}}" bindinput="onAmountInput" />
    </view>

    <view class="field">
      <view class="label">分类</view>
      <picker mode="selector" range="{{categoryNames}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker">{{form.category || '请选择分类'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">备注</view>
      <input class="input" placeholder="可不填" value="{{form.note}}" bindinput="onNoteInput" />
    </view>

    <view class="field">
      <view class="label">日期</view>
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="picker">{{form.date}}</view>
      </picker>
    </view>

    <button class="primary-button submit-button" loading="{{submitting}}" bindtap="submit">保存修改</button>
    <button class="delete-button" loading="{{deleting}}" bindtap="confirmDelete">删除账单</button>
  </view>
</view>
