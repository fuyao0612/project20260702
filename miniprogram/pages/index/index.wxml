<view class="page">
  <view class="summary">
    <view>
      <view class="summary-label">本月支出</view>
      <view class="summary-amount">¥{{expenseTotalText}}</view>
    </view>
    <view class="summary-side">
      <view class="summary-label">本月收入</view>
      <view class="summary-income">¥{{incomeTotalText}}</view>
    </view>
  </view>

  <button class="primary-button add-button" bindtap="goCreate">记一笔</button>
  <button class="secondary-button" bindtap="goStatistics">查看统计</button>

  <view class="section-title">最近账单</view>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{transactions.length === 0}}" class="state-text">暂无账单</view>

  <view wx:else class="transaction-list">
    <view wx:for="{{transactions}}" wx:key="id" class="transaction-item" data-id="{{item.id}}" bindtap="goDetail">
      <view class="transaction-main">
        <view class="transaction-category">{{item.category}}</view>
        <view class="transaction-note">{{item.note || '无备注'}}</view>
      </view>
      <view class="transaction-side">
        <view class="transaction-amount {{item.type === 'income' ? 'income' : 'expense'}}">
          {{item.type === 'income' ? '+' : '-'}}¥{{item.amountText}}
        </view>
        <view class="transaction-time">{{item.dateText}}</view>
      </view>
    </view>
  </view>
</view>
