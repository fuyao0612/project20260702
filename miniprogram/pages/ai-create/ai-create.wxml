<view class="page">
  <button class="settings-button" bindtap="goAISettings">AI 配置</button>

  <view class="field">
    <view class="label">一句话记账</view>
    <textarea class="textarea" placeholder="例如：今天午饭花了18元" value="{{text}}" bindinput="onTextInput" />
  </view>

  <button class="primary-button submit-button" loading="{{generating}}" bindtap="generateDraft">生成草稿</button>
  <button class="secondary-button image-button" loading="{{imageGenerating}}" bindtap="chooseImageAndGenerateDraft">选择图片识别</button>

  <view wx:if="{{draftReady}}" class="draft">
    <view class="section-title">AI 草稿</view>

    <view class="field">
      <view class="label">类型</view>
      <view class="segmented">
        <view class="segment {{form.type === 'expense' ? 'active' : ''}}" data-type="expense" bindtap="chooseType">支出</view>
        <view class="segment {{form.type === 'income' ? 'active' : ''}}" data-type="income" bindtap="chooseType">收入</view>
      </view>
    </view>

    <view class="field">
      <view class="label">金额</view>
      <input class="input" type="digit" value="{{form.amountYuan}}" bindinput="onAmountInput" />
    </view>

    <view class="field">
      <view class="label">分类</view>
      <picker mode="selector" range="{{categoryNames}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker">{{form.category || '请选择分类'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">备注</view>
      <input class="input" value="{{form.note}}" bindinput="onNoteInput" />
    </view>

    <view class="field">
      <view class="label">日期</view>
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="picker">{{form.date}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">时间</view>
      <picker mode="time" value="{{form.time}}" bindchange="onTimeChange">
        <view class="picker">{{form.time}}</view>
      </picker>
    </view>

    <button class="primary-button submit-button" loading="{{saving}}" bindtap="saveDraft">确认保存</button>
  </view>
</view>
